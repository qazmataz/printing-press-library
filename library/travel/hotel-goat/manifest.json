{
  "manifest_version": "0.3",
  "name": "hotel-goat-pp-mcp",
  "display_name": "Google Hotels",
  "version": "4.13.0",
  "description": "Every Google Hotels feature, plus per-OTA price breakdown, local price-drift history, brand-loyalty filters, and date-flex windowing no other tool has.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/hotel-goat-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/hotel-goat-pp-mcp",
      "args": []
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
