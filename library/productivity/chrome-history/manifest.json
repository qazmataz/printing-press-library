{
  "manifest_version": "0.3",
  "name": "chrome-history-pp-mcp",
  "display_name": "Chrome History",
  "version": "4.13.0",
  "description": "Query local Chrome browsing history from a snapshot index; no remote API spec.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/chrome-history-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/chrome-history-pp-mcp",
      "args": []
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin"
    ]
  }
}
